@* Network I/O — Filters virtual/container interfaces, collapsible *@
<div class="panel-header">
    <span class="panel-title">
        <span class="panel-title-icon">🌐</span> Network I/O
    </span>
    @if (_hiddenCount > 0)
    {
        <button class="toggle-btn" @onclick="ToggleShowAll">
            @(_showAll ? "Hide virtual" : $"+{_hiddenCount} hidden")
        </button>
    }
</div>
<div class="panel-body">
    @if (_visibleNetworks.Length > 0)
    {
        <div class="bar-container">
            @foreach (var net in _visibleNetworks)
            {
                <div class="bar-row">
                    <span class="bar-label">@net.InterfaceName</span>
                    <span class="stat-unit" style="min-width: 20px;">Rx</span>
                    <div class="bar-track">
                        <div class="bar-fill green" style="width: @GetBarWidth(net.RxKbPerSec, _maxKbps)%"></div>
                    </div>
                    <span class="bar-value text-green">@FormatSpeed(net.RxKbPerSec)</span>
                </div>
                <div class="bar-row">
                    <span class="bar-label"></span>
                    <span class="stat-unit" style="min-width: 20px;">Tx</span>
                    <div class="bar-track">
                        <div class="bar-fill purple" style="width: @GetBarWidth(net.TxKbPerSec, _maxKbps)%"></div>
                    </div>
                    <span class="bar-value text-purple">@FormatSpeed(net.TxKbPerSec)</span>
                </div>
            }
        </div>
    }
    else
    {
        <div class="stat-label" style="opacity: 0.4;">No network data</div>
    }
</div>

@code {
    [Parameter] public NetworkSnapshot[]? Networks { get; set; }

    private NetworkSnapshot[] _visibleNetworks = [];
    private int _hiddenCount;
    private bool _showAll;
    private double _maxKbps = 50000;

    // Virtual/container interface prefixes to hide by default
    private static readonly string[] HiddenPrefixes = ["veth", "br-", "docker", "lo", "virbr", "vxlan", "flannel", "cali", "cni", "lxc"];

    protected override void OnParametersSet()
    {
        if (Networks == null)
        {
            _visibleNetworks = [];
            _hiddenCount = 0;
            return;
        }

        var physical = Networks.Where(n => !IsVirtualInterface(n.InterfaceName)).ToArray();
        var all = Networks;

        _hiddenCount = all.Length - physical.Length;
        _visibleNetworks = _showAll ? all : physical;

        var max = _visibleNetworks.SelectMany(n => new[] { n.RxKbPerSec, n.TxKbPerSec }).DefaultIfEmpty(0).Max();
        _maxKbps = Math.Max(1000, max * 1.5);
    }

    private static bool IsVirtualInterface(string name) =>
        HiddenPrefixes.Any(p => name.StartsWith(p, StringComparison.OrdinalIgnoreCase));

    private void ToggleShowAll()
    {
        _showAll = !_showAll;
        OnParametersSet(); // Re-filter
    }

    private static string GetBarWidth(double value, double max)
    {
        var pct = max > 0 ? value / max * 100 : 0;
        return Math.Clamp(pct, 0, 100).ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
    }

    private static string FormatSpeed(double kbps)
    {
        if (kbps >= 1024 * 1024) return $"{kbps / 1024 / 1024:F1} GB/s";
        if (kbps >= 1024) return $"{kbps / 1024:F1} MB/s";
        return $"{kbps:F0} KB/s";
    }
}
