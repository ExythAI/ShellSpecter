<div class="panel-header">
    <span class="panel-title">
        <span class="panel-title-icon">🖥️</span> System Details
    </span>
    @if (Info != null)
    {
        <span class="panel-badge">@Info.Architecture</span>
    }
</div>
<div class="panel-body">
    @if (Info != null)
    {
        <div class="sysinfo-grid">
            <div class="sysinfo-row">
                <span class="sysinfo-label">Hostname</span>
                <span class="sysinfo-value">@Info.HostName</span>
            </div>
            <div class="sysinfo-row">
                <span class="sysinfo-label">IP Address</span>
                <span class="sysinfo-value text-cyan">@Info.IpAddress</span>
            </div>
            <div class="sysinfo-row">
                <span class="sysinfo-label">Operating System</span>
                <span class="sysinfo-value">@Info.OperatingSystem</span>
            </div>
            <div class="sysinfo-row">
                <span class="sysinfo-label">Kernel</span>
                <span class="sysinfo-value mono text-dim">@Info.KernelVersion</span>
            </div>
            <div class="sysinfo-row">
                <span class="sysinfo-label">CPU</span>
                <span class="sysinfo-value">@Info.CpuModel</span>
            </div>
            <div class="sysinfo-row">
                <span class="sysinfo-label">Logical Cores</span>
                <span class="sysinfo-value text-purple">@Info.LogicalCores</span>
            </div>
            <div class="sysinfo-row">
                <span class="sysinfo-label">Total RAM</span>
                <span class="sysinfo-value text-cyan">@FormatRam(Info.TotalRamMb)</span>
            </div>
            <div class="sysinfo-row">
                <span class="sysinfo-label">Uptime</span>
                <span class="sysinfo-value text-green">@FormatUptime(Info.UptimeSeconds)</span>
            </div>
        </div>

        @if (Info.DiskInfos.Length > 0)
        {
            <div class="stat-label mt-1 mb-1" style="padding-top: 0.5rem; border-top: 1px solid var(--border-subtle);">
                Disk Volumes
            </div>
            @foreach (var disk in Info.DiskInfos)
            {
                <div class="disk-info-row">
                    <div class="flex-between mb-1">
                        <span class="sysinfo-value" style="font-size: 0.72rem;">@disk.MountPoint</span>
                        <span class="stat-unit">@disk.FileSystem — @disk.UsedGb / @disk.TotalGb GB</span>
                    </div>
                    <div class="bar-track" style="height: 14px;">
                        <div class="bar-fill @GetDiskColor(disk.UsagePercent)" style="width: @disk.UsagePercent.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                    </div>
                    <div style="text-align: right;">
                        <span class="stat-unit @GetDiskTextColor(disk.UsagePercent)">@disk.UsagePercent.ToString("F1")% used — @disk.AvailableGb GB free</span>
                    </div>
                </div>
            }
        }
    }
    else
    {
        <div class="text-dim" style="text-align: center; padding: 1rem;">Waiting for system data...</div>
    }
</div>

@code {
    [Parameter] public SystemInfo? Info { get; set; }

    private static string FormatRam(long mb)
    {
        if (mb >= 1024) return $"{mb / 1024.0:F1} GB";
        return $"{mb} MB";
    }

    private static string FormatUptime(long seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        if (ts.TotalDays >= 1) return $"{(int)ts.TotalDays}d {ts.Hours}h {ts.Minutes}m";
        if (ts.TotalHours >= 1) return $"{ts.Hours}h {ts.Minutes}m {ts.Seconds}s";
        return $"{ts.Minutes}m {ts.Seconds}s";
    }

    private static string GetDiskColor(double pct) => pct switch
    {
        > 90 => "red",
        > 75 => "amber",
        _ => "cyan"
    };

    private static string GetDiskTextColor(double pct) => pct switch
    {
        > 90 => "text-red",
        > 75 => "text-amber",
        _ => ""
    };
}
