@page "/dashboard"
@inject Services.NodeManager Nodes
@inject Services.AuthService Auth
@implements IDisposable

<div class="dashboard-grid fade-in">
    @* Row 1: System Info + CPU (unchanged) *@
    <div class="panel panel-third">
        <SystemInfoPanel Info="@_snapshot?.System" />
    </div>

    <div class="panel panel-two-thirds">
        <CpuPanel Snapshot="@_snapshot?.Cpu" Load="@_snapshot?.Load" />
    </div>

    @* Row 2: Memory + GPU side-by-side (or Memory wider if no GPU) *@
    <div class="panel @(_snapshot?.Gpus?.Length > 0 ? "panel-half" : "panel-two-thirds")">
        <MemoryPanel Snapshot="@_snapshot?.Memory" Pressure="@_snapshot?.Pressure" />
    </div>

    @if (_snapshot?.Gpus?.Length > 0)
    {
        <div class="panel panel-half">
            <GpuPanel Gpus="@_snapshot.Gpus" />
        </div>
    }

    @* Row 3: Disk I/O + Network I/O side-by-side *@
    <div class="panel panel-half">
        <DiskPanel Disks="@_snapshot?.Disks" />
    </div>

    <div class="panel panel-half">
        <NetworkPanel Networks="@_snapshot?.Networks" />
    </div>

    @* Row 4: Process Table (full width) *@
    <div class="panel panel-full">
        <ProcessTable Processes="@_snapshot?.Processes" />
    </div>
</div>

@code {
    private SystemSnapshot? _snapshot;

    protected override void OnInitialized()
    {
        Nodes.OnSnapshot += HandleSnapshot;

        // Auto-connect to the endpoint from login
        if (Nodes.Nodes.Count == 0 && !string.IsNullOrEmpty(Auth.Endpoint))
        {
            _ = Nodes.ConnectAsync(Auth.Endpoint);
        }
    }

    private void HandleSnapshot(string nodeUrl, SystemSnapshot snapshot)
    {
        _snapshot = snapshot;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Nodes.OnSnapshot -= HandleSnapshot;
    }
}
